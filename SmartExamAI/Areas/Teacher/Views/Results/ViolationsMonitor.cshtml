@model SmartExamAI.ViewModels.Teacher.ViolationMonitorViewModel
@{
    ViewData["Title"] = "Violations: " + Model.ExamTitle;
}

@section Breadcrumb {
<nav aria-label="breadcrumb" style="font-size:0.85rem;margin-bottom:1rem;">
  <ol class="breadcrumb" style="background:none;padding:0;margin:0;">
    <li class="breadcrumb-item"><a href="/Teacher/Dashboard" style="color:var(--c-primary);">Home</a></li>
    <li class="breadcrumb-item"><a href="#" style="color:var(--c-primary);">Results</a></li>
    <li class="breadcrumb-item active" style="color:var(--c-muted);">Violations Monitor</li>
  </ol>
</nav>
}




<style>
    .live-header { background: var(--c-card); border: 1px solid var(--c-border); border-radius: 10px; padding: 18px 22px; margin-bottom: 16px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
    .live-header h1 { font-size: 18px; font-weight: 600; color: var(--c-text); margin: 0; }
    .live-header-sub { font-size: 12px; color: var(--c-muted); margin-top: 2px; }
    .live-indicator { display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--c-muted); font-weight: 500; }
    .live-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--c-success); animation: pulse 2s infinite; }
    @@keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(90,138,90,.7); } 70% { box-shadow: 0 0 0 6px rgba(90,138,90,0); } 100% { box-shadow: 0 0 0 0 rgba(90,138,90,0); } }

    .stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 16px; }
    .stat-card { background: var(--c-card); border: 1px solid var(--c-border); border-radius: 10px; padding: 16px 18px; }
    .stat-label { font-size: 10px; text-transform: uppercase; letter-spacing: .6px; color: var(--c-muted); margin-bottom: 6px; }
    .stat-value { font-size: 26px; font-weight: 600; color: var(--c-text); line-height: 1; }
    .stat-sub { font-size: 11px; margin-top: 4px; }

    .card-block { background: var(--c-card); border: 1px solid var(--c-border); border-radius: 10px; overflow: hidden; }
    .card-block-header { display: flex; justify-content: space-between; align-items: center; padding: 16px 18px; border-bottom: 1px solid var(--c-border); }
    .card-block-header h2 { font-size: 15px; font-weight: 600; color: var(--c-text); margin: 0; }

    .detail-table { width: 100%; border-collapse: collapse; }
    .detail-table th { font-size: 10px; text-transform: uppercase; letter-spacing: .5px; color: var(--c-muted); font-weight: 600; padding: 10px 18px; text-align: left; border-bottom: 1px solid var(--c-border); }
    .detail-table td { padding: 12px 18px; font-size: 13px; color: var(--c-text); border-bottom: 1px solid var(--c-border); vertical-align: middle; }
    .detail-table tr:last-child td { border-bottom: none; }

    @@keyframes skelPulse { 0%,100% { opacity: 1; } 50% { opacity: .4; } }
    .skel-cell { height: 14px; background: var(--c-page-bg); border-radius: 4px; animation: skelPulse 1.5s infinite; }

    .conn-lost { background: #fde8e8; color: #8b2020; border-radius: 6px; padding: 6px 14px; font-size: 12px; display: none; align-items: center; gap: 8px; }
    .conn-lost button { background: none; border: none; cursor: pointer; color: #8b2020; font-size: 14px; }

    .last-updated { font-size: 11px; color: var(--c-muted); }

    @@media (max-width: 767px) { .stat-grid { grid-template-columns: 1fr; } }
</style>

<!-- Top bar -->
<div class="live-header">
    <div>
        <h1>@Model.ExamTitle</h1>
        <div class="live-header-sub">Violations Monitor</div>
    </div>
    <div style="display: flex; align-items: center; gap: 16px;">
        <div id="connLost" class="conn-lost">
            Connection lost <button onclick="this.parentElement.style.display='none';">&times;</button>
        </div>
        <div class="live-indicator">
            <span class="live-dot"></span>
            <span>Polling every 10s</span>
        </div>
    </div>
</div>

<!-- 3 stat cards -->
<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-label">Active Students</div>
        <div class="stat-value" id="statActive">--</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Students with Violations</div>
        <div class="stat-value" id="statViolations">--</div>
        <div class="stat-sub" style="color: var(--c-warning);">Need attention</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Terminated</div>
        <div class="stat-value" id="statTerminated">--</div>
        <div class="stat-sub" style="color: var(--c-danger);">Auto-terminated</div>
    </div>
</div>

<!-- Live violations table -->
<div class="card-block">
    <div class="card-block-header">
        <h2>Live Violation Data</h2>
        <span class="last-updated" id="lastUpdated">Loading...</span>
    </div>
    <table class="detail-table">
        <thead>
            <tr>
                <th>Student</th>
                <th>Violations</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody id="violationsBody">
            <!-- Skeleton rows -->
            <tr class="skel-row"><td><div class="skel-cell"></div></td><td><div class="skel-cell"></div></td><td><div class="skel-cell"></div></td></tr>
            <tr class="skel-row"><td><div class="skel-cell"></div></td><td><div class="skel-cell"></div></td><td><div class="skel-cell"></div></td></tr>
            <tr class="skel-row"><td><div class="skel-cell"></div></td><td><div class="skel-cell"></div></td><td><div class="skel-cell"></div></td></tr>
        </tbody>
    </table>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        var tbody = document.getElementById('violationsBody');
        var statActive = document.getElementById('statActive');
        var statViolations = document.getElementById('statViolations');
        var statTerminated = document.getElementById('statTerminated');
        var lastUpdated = document.getElementById('lastUpdated');
        var connLost = document.getElementById('connLost');
        var threshold = @Html.Raw(Json.Serialize(0));

        function escapeHtml(v) { return String(v ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

        function getStatusBadge(student, halfThresh) {
            if (student.isTerminated) return '<span class="badge-danger">Terminated</span>';
            if (student.submittedAt) return '<span class="badge-muted">Submitted</span>';
            if (student.violationCount >= halfThresh && halfThresh > 0) return '<span class="badge-warning">At Risk</span>';
            return '<span class="badge-success">Active</span>';
        }

        function getViolationStyle(count, halfThresh, atThresh) {
            if (count === 0) return 'color: var(--c-muted);';
            if (atThresh) return 'color: var(--c-danger); font-weight: 700;';
            if (count >= halfThresh && halfThresh > 0) return 'color: var(--c-warning); font-weight: 600;';
            return 'color: var(--c-text); font-weight: 500;';
        }

        function loadData() {
            fetch('@Url.Action("ViolationsData", "Results", new { area = "Teacher", examId = Model.ExamId })')
                .then(function(r) { return r.json(); })
                .then(function(response) {
                    connLost.style.display = 'none';
                    document.querySelectorAll('.skel-row').forEach(function(r) { r.remove(); });

                    if (response.allSubmitted) {
                        if (window.pollInterval) clearInterval(window.pollInterval);
                        var liveIndicator = document.querySelector('.live-indicator');
                        if (liveIndicator) {
                            liveIndicator.innerHTML = '<span style="font-size:12px; color:var(--c-muted);">All students have submitted — monitoring complete</span>';
                        }
                    }

                    var data = response.data || [];

                    if (!data || !data.length) {
                        statActive.textContent = '0';
                        statViolations.textContent = '0';
                        statTerminated.textContent = '0';
                        tbody.innerHTML = '<tr><td colspan="3" class="empty-state">No submissions to monitor yet.</td></tr>';
                        lastUpdated.textContent = 'Updated: ' + new Date().toLocaleTimeString();
                        return;
                    }

                    // Sort: terminated first, then by violation count desc, then alphabetical
                    data.sort(function(a, b) {
                        if (a.isTerminated !== b.isTerminated) return a.isTerminated ? -1 : 1;
                        if (b.violationCount !== a.violationCount) return b.violationCount - a.violationCount;
                        return (a.studentName || '').localeCompare(b.studentName || '');
                    });

                    var activeCount = 0;
                    var violationStudents = 0;
                    var terminatedCount = 0;

                    data.forEach(function(s) {
                        if (s.isTerminated) terminatedCount++;
                        else activeCount++;
                        if (s.violationCount > 0) violationStudents++;
                    });

                    statActive.textContent = activeCount;
                    statViolations.textContent = violationStudents;
                    statTerminated.textContent = terminatedCount;

                    // Determine threshold from violation data
                    var maxV = data.reduce(function(m, s) { return Math.max(m, s.violationCount); }, 0);
                    var halfThresh = Math.ceil(maxV / 2);

                    var html = '';
                    data.forEach(function(s) {
                        var atThresh = s.isTerminated;
                        var vStyle = getViolationStyle(s.violationCount, halfThresh, atThresh);
                        var rowBg = s.isTerminated ? 'background: rgba(184,92,92,0.06);' : '';

                        html += '<tr style="' + rowBg + '">' +
                            '<td style="font-weight:500;">' + escapeHtml(s.studentName) + '</td>' +
                            '<td style="' + vStyle + '">' + s.violationCount + '</td>' +
                            '<td>' + getStatusBadge(s, halfThresh) + '</td>' +
                            '</tr>';
                    });

                    tbody.innerHTML = html;
                    lastUpdated.textContent = 'Updated: ' + new Date().toLocaleTimeString();
                })
                .catch(function() {
                    connLost.style.display = 'flex';
                });
        }

        loadData();
        window.pollInterval = setInterval(loadData, 10000);
    });
</script>
}

