@model SmartExamAI.ViewModels.Teacher.TeacherDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var teacherName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Teacher";
    var firstName = teacherName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? teacherName;
}

<style>
    .dash-greeting { margin-bottom: 24px; }
    .dash-greeting h1 { font-size: 22px; font-weight: 700; color: var(--c-text); margin: 0 0 4px; }
    .dash-greeting p { font-size: 13px; color: var(--c-muted); margin: 0; }

    .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 24px; }
    .stat-card {
        background: var(--c-card); border: 1px solid var(--c-border); border-radius: 10px;
        padding: 18px; text-align: center;
    }
    .stat-num { font-size: 28px; font-weight: 700; line-height: 1; margin-bottom: 4px; }
    .stat-lbl { font-size: 11px; color: var(--c-muted); text-transform: uppercase; letter-spacing: 0.5px; }

    .dash-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 20px; }
    .dash-block {
        background: var(--c-card); border: 1px solid var(--c-border); border-radius: 10px;
    }
    .dash-block-head {
        padding: 14px 18px; border-bottom: 1px solid var(--c-border);
        font-size: 14px; font-weight: 600; color: var(--c-text);
        display: flex; justify-content: space-between; align-items: center;
    }
    .dash-block-body { padding: 16px 18px; }

    .item-row {
        display: flex; justify-content: space-between; align-items: center;
        padding: 10px 0; border-bottom: 1px solid var(--c-border);
    }
    .item-row:last-child { border-bottom: none; }
    .item-title { font-size: 13px; font-weight: 600; color: var(--c-text); }
    .item-sub { font-size: 11px; color: var(--c-muted); margin-top: 2px; }

    .btn-action {
        display: inline-block; padding: 5px 14px; background: var(--c-primary);
        color: #fff; border-radius: 6px; text-decoration: none; font-size: 12px; font-weight: 500;
    }
    .btn-action:hover { background: var(--c-primary-hover); color: #fff; }
    .btn-action-outline {
        display: inline-block; padding: 4px 12px; background: #F8F9FA;
        color: var(--c-text); border: 1px solid var(--c-border); border-radius: 6px;
        text-decoration: none; font-size: 12px; font-weight: 500;
    }
    .btn-action-outline:hover { background: #eee; color: var(--c-text); }

    .badge-count {
        font-size: 11px; background: var(--c-warning); color: #fff;
        padding: 2px 8px; border-radius: 10px; font-weight: 700;
    }

    .activity-dot {
        width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 5px;
    }
    .dot-green { background: var(--c-success); }
    .dot-red { background: var(--c-danger); }

    @@media (max-width: 767px) {
        .stats-row { grid-template-columns: repeat(2, 1fr); }
        .dash-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="dash-greeting">
    <h1>Hi, @firstName! 👋</h1>
    <p>Here's your teaching overview</p>
</div>

<!-- Stats -->
<div class="stats-row">
    <div class="stat-card">
        <div class="stat-num" style="color: var(--c-primary);">@Model.TotalCourses</div>
        <div class="stat-lbl">Courses</div>
    </div>
    <div class="stat-card">
        <div class="stat-num" style="color: var(--c-text);">@Model.TotalStudents</div>
        <div class="stat-lbl">Students</div>
    </div>
    <div class="stat-card">
        <div class="stat-num" style="color: var(--c-success);">@Model.ActiveExams</div>
        <div class="stat-lbl">Active Exams</div>
    </div>
    <div class="stat-card">
        <div class="stat-num" style="color: var(--c-warning);">@Model.PendingGrading</div>
        <div class="stat-lbl">To Grade</div>
    </div>
</div>

<!-- Grid -->
<div class="dash-grid">
    <!-- Left: Courses + Needs Grading -->
    <div>
        <!-- My Courses -->
        <div class="dash-block" style="margin-bottom: 20px;">
            <div class="dash-block-head">
                My Courses
                <a href="@Url.Action("Create", "Courses", new { area = "Teacher" })" class="btn-action">New Course</a>
            </div>
            <div class="dash-block-body">
                @{
                    var recentCourses = ViewData["RecentCourses"] as List<SmartExamAI.Models.Course> ?? new List<SmartExamAI.Models.Course>();
                }
                @if (!recentCourses.Any())
                {
                    <div class="empty-state" style="padding: 1rem;">No courses yet</div>
                }
                else
                {
                    @foreach (var course in recentCourses)
                    {
                        <div class="item-row">
                            <div>
                                <div class="item-title">@course.Title</div>
                                @if (!string.IsNullOrWhiteSpace(course.Tagline))
                                {
                                    <div class="item-sub">@course.Tagline</div>
                                }
                            </div>
                            <a href="/Teacher/Courses/@course.Id" class="btn-action-outline">Open</a>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Needs Grading -->
        <div class="dash-block">
            <div class="dash-block-head">
                Needs Grading
                @if (Model.NeedsGradingList.Any())
                {
                    <span class="badge-count">@Model.PendingGrading</span>
                }
            </div>
            <div class="dash-block-body">
                @if (!Model.NeedsGradingList.Any())
                {
                    <div class="empty-state" style="padding: 1rem;">All caught up!</div>
                }
                else
                {
                    @foreach (var item in Model.NeedsGradingList)
                    {
                        <div class="item-row">
                            <div>
                                <div class="item-title">@item.StudentName</div>
                                <div class="item-sub">@item.ExamTitle · @item.CourseTitle</div>
                            </div>
                            <a href="/Teacher/Results/GradeSubmission/@item.SubmissionId" class="btn-action-outline">Grade</a>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Right: Recent Activity -->
    <div>
        <div class="dash-block">
            <div class="dash-block-head">Recent Activity</div>
            <div class="dash-block-body">
                @if (!Model.RecentActivity.Any())
                {
                    <div class="empty-state" style="padding: 1rem;">No activity yet</div>
                }
                else
                {
                    @foreach (var activity in Model.RecentActivity)
                    {
                        var timeSpan = DateTime.UtcNow - activity.OccurredAt;
                        string timeAgo = timeSpan.TotalMinutes < 60 ? $"{(int)timeSpan.TotalMinutes}m ago" :
                                         (timeSpan.TotalHours < 24 ? $"{(int)timeSpan.TotalHours}h ago" : $"{(int)timeSpan.TotalDays}d ago");

                        <div class="item-row" style="gap: 10px;">
                            <div style="display:flex;gap:8px;align-items:flex-start;">
                                <div class="activity-dot @(activity.Type == "Submission" ? "dot-green" : "dot-red")"></div>
                                <div>
                                    <div class="item-title" style="font-weight:500;">@activity.StudentName @(activity.Type == "Submission" ? "submitted" : "violation on") @activity.ExamTitle</div>
                                    <div class="item-sub">@timeAgo</div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
