@model SmartExamAI.ViewModels.Teacher.CreateExamViewModel
@{
    ViewData["Title"] = "Create Exam";
    var courseTitle = ViewData["CourseTitle"]?.ToString() ?? "Course";
    var startValue = Model.StartTime == default ? string.Empty : Model.StartTime.ToString("yyyy-MM-dd HH:mm");
}

@section Breadcrumb {
<nav aria-label="breadcrumb" style="font-size:0.85rem;margin-bottom:1rem;">
  <ol class="breadcrumb" style="background:none;padding:0;margin:0;">
    <li class="breadcrumb-item"><a href="/Teacher/Dashboard" style="color:var(--c-primary);">Home</a></li>
    <li class="breadcrumb-item"><a href="#" style="color:var(--c-primary);">Exams</a></li>
    <li class="breadcrumb-item active" style="color:var(--c-muted);">Create Exam</li>
  </ol>
</nav>
}




<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />

<style>
    .flatpickr-day.selected,
    .flatpickr-day.startRange,
    .flatpickr-day.endRange,
    .flatpickr-day.selected:hover { background: var(--c-primary); border-color: var(--c-primary); }
    .flatpickr-day.today { border-color: var(--c-warning); }
    .flatpickr-time input:hover,
    .flatpickr-time .flatpickr-am-pm:hover,
    .flatpickr-time input:focus,
    .flatpickr-time .flatpickr-am-pm:focus { background: var(--c-page-bg); }

    .exam-card { background: var(--c-card); border: 1px solid var(--c-border); border-radius: 10px; padding: 22px 26px; margin-bottom: 16px; }
    .exam-card h2 { font-size: 15px; font-weight: 600; color: var(--c-text); margin: 0 0 16px 0; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-grid .full-width { grid-column: 1 / -1; }
    .field-label { font-size: 12px; font-weight: 600; color: var(--c-text); margin-bottom: 6px; display: block; }
    .field-hint { font-size: 11px; color: var(--c-muted); margin-top: 4px; }
    .field-input { width: 100%; padding: 8px 12px; border: 1px solid var(--c-border); border-radius: 7px; font-size: 13px; color: var(--c-text); background: var(--c-card); outline: none; transition: border-color .15s; }
    .field-input:focus { border-color: var(--c-primary); }
    .field-readonly { background: var(--c-page-bg); color: var(--c-muted); cursor: default; }
    .field-suffix { display: flex; align-items: center; gap: 0; }
    .field-suffix .field-input { border-top-right-radius: 0; border-bottom-right-radius: 0; }
    .field-suffix-label { padding: 8px 12px; border: 1px solid var(--c-border); border-left: none; border-radius: 0 7px 7px 0; font-size: 12px; color: var(--c-muted); background: var(--c-page-bg); white-space: nowrap; }

    .toggle-switch { position: relative; display: inline-flex; align-items: center; gap: 10px; cursor: pointer; }
    .toggle-switch input { display: none; }
    .toggle-track { width: 38px; height: 20px; border-radius: 10px; background: var(--c-border); position: relative; transition: background .2s; }
    .toggle-switch input:checked + .toggle-track { background: var(--c-primary); }
    .toggle-track::after { content: ''; position: absolute; width: 16px; height: 16px; border-radius: 50%; background: var(--c-card); top: 2px; left: 2px; transition: transform .2s; }
    .toggle-switch input:checked + .toggle-track::after { transform: translateX(18px); }

    .validation-box { background: #F8D7DA; color: #721C24; border-radius: 7px; padding: 10px 14px; font-size: 12px; margin-bottom: 16px; }

    .card-block { background: var(--c-card); border: 1px solid var(--c-border); border-radius: 10px; overflow: hidden; margin-bottom: 16px; }
    .card-block-header { display: flex; justify-content: space-between; align-items: center; padding: 16px 18px; border-bottom: 1px solid var(--c-border); }
    .card-block-header h2 { font-size: 15px; font-weight: 600; color: var(--c-text); margin: 0; }
    .marks-total { font-size: 13px; font-weight: 600; color: var(--c-primary); }

    .q-row { background: var(--c-card); border: 1px solid var(--c-border); border-radius: 8px; padding: 14px 16px; margin: 8px 18px; display: flex; align-items: center; gap: 12px; }
    .q-row:last-child { margin-bottom: 18px; }
    .q-num { width: 24px; height: 24px; border-radius: 50%; background: var(--c-primary); color: #fff; font-size: 11px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-weight: 600; }
    .q-text { flex: 1; font-size: 13px; font-weight: 500; color: var(--c-text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .q-marks { font-size: 11px; color: var(--c-muted); white-space: nowrap; }
    .q-delete { border: none; background: none; cursor: pointer; padding: 4px; color: var(--c-danger); }

    .add-q-form { padding: 18px; border-top: 1px solid var(--c-border); display: none; }
    .add-q-form.visible { display: block; }
    .add-q-form textarea { width: 100%; padding: 8px 12px; border: 1px solid var(--c-border); border-radius: 7px; font-size: 13px; resize: vertical; }
    .add-q-form .opts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 12px; }
    .opt-row { display: flex; align-items: center; gap: 8px; }
    .opt-row input[type="text"] { flex: 1; padding: 6px 10px; border: 1px solid var(--c-border); border-radius: 6px; font-size: 12px; }

    .btn-sm-primary { font-size: 12px; padding: 5px 14px; background: var(--c-primary); color: #fff; border: none; border-radius: 6px; cursor: pointer; font-weight: 500; transition: background .15s; }
    .btn-sm-primary:hover { background: var(--c-primary-hover); }
    .btn-sm-outline { font-size: 12px; padding: 5px 12px; border: 1px solid var(--c-border); border-radius: 6px; background: var(--c-card); color: var(--c-text); cursor: pointer; font-weight: 500; text-decoration: none; }

    .bottom-bar { display: flex; justify-content: space-between; align-items: center; margin-top: 8px; }

    .question-option-correct { background-color: rgba(90, 138, 90, 0.12); border-color: var(--c-success) !important; }

    @@media (max-width: 767px) { .form-grid { grid-template-columns: 1fr; } }
</style>

<!-- Top: Exam Settings -->
<div class="exam-card">
    <h2>Exam Settings</h2>
    <form id="examSettingsForm" asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CourseId" />
        <div id="settingsError" class="validation-box" style="display:none;"></div>
        <div asp-validation-summary="All" class="validation-box" style="@(ViewContext.ModelState.IsValid ? "display:none;" : "")"></div>

        <div class="form-grid">
            <div class="full-width">
                <label class="field-label field-required">Title</label>
                <input asp-for="Title" class="field-input" id="titleInput" placeholder="e.g., Midterm Exam" />
                <span asp-validation-for="Title" style="color: var(--c-danger); font-size: 11px;"></span>
            </div>
            <div>
                <label class="field-label">Course</label>
                <input type="text" class="field-input field-readonly" value="@courseTitle" readonly />
            </div>
            <div>
                <label class="field-label field-required">Start Time</label>
                <input asp-for="StartTime" class="field-input" id="startTimeInput" value="@startValue" autocomplete="off" />
                <span asp-validation-for="StartTime" style="color: var(--c-danger); font-size: 11px;"></span>
            </div>
            <div>
                <label class="field-label field-required">Duration</label>
                <div class="field-suffix">
                    <input asp-for="DurationMinutes" class="field-input" id="durationInput" type="number" min="1" max="480" />
                    <span class="field-suffix-label">minutes</span>
                </div>
                <span asp-validation-for="DurationMinutes" style="color: var(--c-danger); font-size: 11px;"></span>
            </div>
            <div>
                <label class="field-label field-required">Violation Threshold</label>
                <input asp-for="ViolationThreshold" class="field-input" type="number" min="1" />
                <div class="field-hint">Exam auto-terminates when student reaches this count</div>
                <span asp-validation-for="ViolationThreshold" style="color: var(--c-danger); font-size: 11px;"></span>
            </div>
            <div style="display: flex; align-items: flex-end;">
                <label class="toggle-switch">
                    <input asp-for="QuestionRandomization" type="checkbox" />
                    <span class="toggle-track"></span>
                    <span class="field-label" style="margin: 0;">Question Randomization</span>
                </label>
            </div>
        </div>

        <div style="display: flex; justify-content: flex-end; margin-top: 20px;">
            <button type="button" class="btn-sm-primary" id="saveSettingsNextButton" style="padding: 8px 20px; font-size: 13px;">Save &amp; Add Questions</button>
        </div>
    </form>
</div>

<!-- Bottom: Questions -->
<div class="card-block" id="questionsSection">
    <div class="card-block-header">
        <h2>Questions <span class="marks-total" id="totalMarksCounter">0 marks total</span></h2>
        <button type="button" class="btn-sm-primary" id="toggleAddForm">Add Question</button>
    </div>

    <div id="questionsList">
        <div id="emptyQuestionsState" class="empty-state">No questions yet. Add your first question.</div>
    </div>

    <!-- Add Question inline form -->
    <div id="addQuestionForm" class="add-q-form">
        <div id="questionError" class="validation-box" style="display:none;"></div>
        <div style="margin-bottom: 12px;">
            <label class="field-label">Question Text</label>
            <textarea id="questionText" rows="3" placeholder="Enter question text..."></textarea>
        </div>
        <div class="form-grid" style="margin-bottom: 12px;">
            <div>
                <label class="field-label">Type</label>
                <select id="questionTypeSelect" class="field-input" style="cursor:pointer;">
                    <option value="MCQ">MCQ</option>
                    <option value="TrueFalse">True / False</option>
                    <option value="ShortAnswer">Short Answer</option>
                </select>
            </div>
            <div>
                <label class="field-label">Marks</label>
                <input type="number" id="questionMarks" class="field-input" value="1" min="1" />
            </div>
        </div>

        <div id="mcqOptionsSection">
            <label class="field-label">Options (select correct answer)</label>
            <div class="opts-grid">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="opt-row">
                        <input type="radio" name="mcqCorrectOption" value="@i" />
                        <input type="text" class="mcq-option-input" placeholder="Option @(i + 1)" />
                    </div>
                }
            </div>
        </div>

        <div id="trueFalseOptionsSection" style="display:none;">
            <label class="field-label">Correct Answer</label>
            <div style="display: flex; gap: 12px; margin-top: 6px;">
                <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px;color:var(--c-text);">
                    <input type="radio" name="trueFalseCorrectAnswer" value="True" checked /> True
                </label>
                <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px;color:var(--c-text);">
                    <input type="radio" name="trueFalseCorrectAnswer" value="False" /> False
                </label>
            </div>
        </div>

        <div id="shortAnswerNote" style="display:none; margin-top: 12px; padding: 10px 14px; background: var(--c-page-bg); border-radius: 7px; font-size: 12px; color: var(--c-muted);">
            Short answer questions are graded manually.
        </div>

        <div style="display: flex; justify-content: flex-end; gap: 8px; margin-top: 16px;">
            <button type="button" class="btn-sm-outline" id="cancelAddQuestion">Cancel</button>
            <button type="button" class="btn-sm-primary" id="addQuestionButton">Save Question</button>
        </div>
    </div>
</div>

<!-- Bottom action bar -->
<div class="bottom-bar" style="justify-content: flex-end;">
    <button type="button" class="btn-sm-primary" id="saveExamButton" style="padding: 8px 20px; font-size: 13px;">Save Exam</button>
</div>

<input type="hidden" id="currentExamId" />

<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
    const settingsForm = document.getElementById('examSettingsForm');
    const settingsError = document.getElementById('settingsError');
    const questionError = document.getElementById('questionError');
    const startTimeInput = document.getElementById('startTimeInput');
    const durationInput = document.getElementById('durationInput');
    const currentExamIdInput = document.getElementById('currentExamId');
    const questionsList = document.getElementById('questionsList');
    const totalMarksCounter = document.getElementById('totalMarksCounter');
    const addForm = document.getElementById('addQuestionForm');
    const typeSelect = document.getElementById('questionTypeSelect');

    flatpickr(startTimeInput, { enableTime: true, dateFormat: 'Y-m-d H:i', time_24hr: true });

    function token() { return document.querySelector('input[name="__RequestVerificationToken"]').value; }
    function showError(el, msg) { el.textContent = msg; el.style.display = 'block'; }
    function clearError(el) { el.style.display = 'none'; el.textContent = ''; }
    function escapeHtml(v) { return String(v ?? '').replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;').replaceAll('"','&quot;').replaceAll("'",'&#039;'); }
    function selectedQuestionType() { return typeSelect.value; }

    function updateQuestionTypeSections() {
        var t = selectedQuestionType();
        document.getElementById('mcqOptionsSection').style.display = t === 'MCQ' ? '' : 'none';
        document.getElementById('trueFalseOptionsSection').style.display = t === 'TrueFalse' ? '' : 'none';
        document.getElementById('shortAnswerNote').style.display = t === 'ShortAnswer' ? '' : 'none';
    }
    typeSelect.addEventListener('change', updateQuestionTypeSections);
    updateQuestionTypeSections();

    document.getElementById('toggleAddForm').addEventListener('click', function() { addForm.classList.toggle('visible'); });
    document.getElementById('cancelAddQuestion').addEventListener('click', function() { addForm.classList.remove('visible'); });

    function typeBadge(t) {
        if (t === 'MCQ') return 'badge-primary';
        if (t === 'TrueFalse') return 'badge-muted';
        return 'badge-warning';
    }

    function normalizeQuestion(q) { return { id: q.id ?? q.Id, text: q.text ?? q.Text, type: q.type ?? q.Type, marks: q.marks ?? q.Marks, orderIndex: q.orderIndex ?? q.OrderIndex, options: q.options ?? q.Options ?? [] }; }

    function updateEmptyState() {
        var count = document.querySelectorAll('[data-question-card]').length;
        document.getElementById('emptyQuestionsState').style.display = count === 0 ? '' : 'none';
    }

    function updateTotalMarks() {
        var total = Array.from(document.querySelectorAll('[data-question-card]')).reduce(function(s, c) { return s + Number(c.getAttribute('data-marks') || 0); }, 0);
        totalMarksCounter.textContent = total + ' marks total';
    }

    function renumberCards() {
        document.querySelectorAll('[data-question-card] .q-num').forEach(function(el, i) { el.textContent = i + 1; });
    }

    function appendQuestionCard(raw) {
        var q = normalizeQuestion(raw);
        var truncText = q.text.length > 80 ? q.text.substring(0, 80) + '...' : q.text;
        var row = document.createElement('div');
        row.className = 'q-row';
        row.setAttribute('data-question-card', 'true');
        row.setAttribute('data-question-id', q.id);
        row.setAttribute('data-marks', q.marks);
        row.innerHTML = '<span class="q-num">' + q.orderIndex + '</span>' +
            '<span class="q-text">' + escapeHtml(truncText) + '</span>' +
            '<span class="' + typeBadge(q.type) + '">' + escapeHtml(q.type) + '</span>' +
            '<span class="q-marks">' + q.marks + ' marks</span>' +
            '<button type="button" class="q-delete delete-question-button" title="Delete"><i class="bi bi-trash"></i></button>';
        questionsList.appendChild(row);
        row.querySelector('.delete-question-button').addEventListener('click', function() { deleteQuestion(q.id, row); });
        renumberCards(); updateTotalMarks(); updateEmptyState();
    }

    function clearQuestionForm() {
        document.getElementById('questionText').value = '';
        document.getElementById('questionMarks').value = '1';
        typeSelect.value = 'MCQ';
        document.querySelectorAll('.mcq-option-input').forEach(function(i) { i.value = ''; });
        document.querySelectorAll('input[name="mcqCorrectOption"]').forEach(function(i) { i.checked = false; });
        document.querySelector('input[name="trueFalseCorrectAnswer"][value="True"]').checked = true;
        updateQuestionTypeSections();
    }

    function ensureExamSaved() {
        clearError(settingsError);
        if (currentExamIdInput.value) return Promise.resolve(true);
        if (!document.getElementById('titleInput').value.trim()) { showError(settingsError, 'Title is required.'); return Promise.resolve(false); }
        if (!startTimeInput.value.trim()) { showError(settingsError, 'Start Time is required.'); return Promise.resolve(false); }
        var dur = Number(durationInput.value);
        if (!dur || dur < 1 || dur > 480) { showError(settingsError, 'Duration must be between 1 and 480 minutes.'); return Promise.resolve(false); }
        var formData = new FormData(settingsForm);
        return fetch('/Teacher/Exams/Create', { method: 'POST', body: formData, headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function(r) { return r.json(); })
            .then(function(d) { if (!d.success) { showError(settingsError, d.message || 'Unable to save exam settings.'); return false; } currentExamIdInput.value = d.examId; return true; })
            .catch(function() { showError(settingsError, 'Unable to save exam settings.'); return false; });
    }

    document.getElementById('saveSettingsNextButton').addEventListener('click', function() {
        ensureExamSaved().then(function(ok) { if (ok) { addForm.classList.add('visible'); } });
    });

    document.getElementById('addQuestionButton').addEventListener('click', function() {
        clearError(questionError);
        var examId = currentExamIdInput.value;
        if (!examId) { ensureExamSaved().then(function(ok) { if (!ok) showError(questionError, 'Save exam settings first.'); }); return; }
        var formData = new FormData();
        formData.append('__RequestVerificationToken', token());
        formData.append('ExamId', examId);
        formData.append('Text', document.getElementById('questionText').value);
        formData.append('Type', selectedQuestionType());
        formData.append('Marks', document.getElementById('questionMarks').value);
        document.querySelectorAll('.mcq-option-input').forEach(function(input, index) { formData.append('Options[' + index + ']', input.value); });
        var correctMcq = document.querySelector('input[name="mcqCorrectOption"]:checked');
        if (correctMcq) formData.append('CorrectOptionIndex', correctMcq.value);
        var correctTF = document.querySelector('input[name="trueFalseCorrectAnswer"]:checked');
        if (correctTF) formData.append('CorrectAnswer', correctTF.value);
        fetch('/Teacher/Exams/AddQuestion', { method: 'POST', body: formData, headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function(r) { return r.json(); })
            .then(function(d) { if (!d.success) { showError(questionError, d.message || 'Unable to add question.'); return; } appendQuestionCard(d.question); clearQuestionForm(); })
            .catch(function() { showError(questionError, 'Unable to add question.'); });
    });

    function deleteQuestion(questionId, card) {
        if (!confirm('Remove this question?')) return;
        var formData = new FormData();
        formData.append('__RequestVerificationToken', token());
        fetch('/Teacher/Exams/DeleteQuestion/' + questionId, { method: 'POST', body: formData, headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function(r) { return r.json(); })
            .then(function(d) { if (!d.success) { showError(questionError, d.message || 'Unable to delete question.'); return; } card.remove(); renumberCards(); updateTotalMarks(); updateEmptyState(); })
            .catch(function() { showError(questionError, 'Unable to delete question.'); });
    }

    document.getElementById('saveExamButton').addEventListener('click', function() {
        ensureExamSaved().then(function(ok) { if (ok) window.location.href = '/Teacher/Exams/Details/' + currentExamIdInput.value; });
    });

    updateEmptyState();
</script>

