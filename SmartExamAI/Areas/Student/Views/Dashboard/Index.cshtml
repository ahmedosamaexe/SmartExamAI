@model SmartExamAI.ViewModels.Student.StudentDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var avgDisplay = Model.AverageScore.HasValue ? $"{Model.AverageScore.Value:0}%" : "—";
    var avgColor = Model.AverageScore.HasValue && Model.AverageScore.Value >= 60 ? "var(--c-success)" : "var(--c-danger)";
    if (!Model.AverageScore.HasValue) avgColor = "var(--c-muted)";
    var studentName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Student";
    var firstName = studentName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? studentName;
}

<style>
    .dash-greeting { margin-bottom: 24px; }
    .dash-greeting h1 { font-size: 22px; font-weight: 700; color: var(--c-text); margin: 0 0 4px; }
    .dash-greeting p { font-size: 13px; color: var(--c-muted); margin: 0; }

    .stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 24px; }
    .stat-card {
        background: var(--c-card); border: 1px solid var(--c-border); border-radius: 10px;
        padding: 18px; text-align: center;
    }
    .stat-num { font-size: 28px; font-weight: 700; line-height: 1; margin-bottom: 4px; }
    .stat-lbl { font-size: 11px; color: var(--c-muted); text-transform: uppercase; letter-spacing: 0.5px; }

    .dash-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .dash-block {
        background: var(--c-card); border: 1px solid var(--c-border); border-radius: 10px;
    }
    .dash-block-head {
        padding: 14px 18px; border-bottom: 1px solid var(--c-border);
        font-size: 14px; font-weight: 600; color: var(--c-text);
        display: flex; justify-content: space-between; align-items: center;
    }
    .dash-block-body { padding: 16px 18px; }

    .exam-row {
        display: flex; justify-content: space-between; align-items: center;
        padding: 10px 0; border-bottom: 1px solid var(--c-border);
    }
    .exam-row:last-child { border-bottom: none; }
    .exam-row-title { font-size: 13px; font-weight: 600; color: var(--c-text); }
    .exam-row-sub { font-size: 11px; color: var(--c-muted); margin-top: 2px; }

    .score-pill {
        font-size: 12px; font-weight: 600; padding: 3px 10px; border-radius: 12px;
    }
    .score-pass { background: #D4EDDA; color: #155724; }
    .score-fail { background: #F8D7DA; color: #721C24; }

    .btn-action {
        display: inline-block; padding: 5px 14px; background: var(--c-primary);
        color: #fff; border-radius: 6px; text-decoration: none; font-size: 12px; font-weight: 500;
    }
    .btn-action:hover { background: var(--c-primary-hover); color: #fff; }

    @@media (max-width: 767px) {
        .stats-row { grid-template-columns: 1fr; }
        .dash-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="dash-greeting">
    <h1>Hi, @firstName! 👋</h1>
    <p>Here's your overview</p>
</div>

<!-- Stats -->
<div class="stats-row">
    <div class="stat-card">
        <div class="stat-num" style="color: var(--c-primary);">@Model.EnrolledCourses</div>
        <div class="stat-lbl">Courses</div>
    </div>
    <div class="stat-card">
        <div class="stat-num" style="color: var(--c-text);">@Model.CompletedExams</div>
        <div class="stat-lbl">Exams Done</div>
    </div>
    <div class="stat-card">
        <div class="stat-num" style="color: @avgColor;">@avgDisplay</div>
        <div class="stat-lbl">Average</div>
    </div>
</div>

<!-- Two columns -->
<div class="dash-grid">
    <!-- Upcoming Exams -->
    <div class="dash-block">
        <div class="dash-block-head">Upcoming Exams</div>
        <div class="dash-block-body">
            @if (!Model.UpcomingExams.Any())
            {
                <div class="empty-state" style="padding: 1rem;">No upcoming exams</div>
            }
            else
            {
                @foreach (var exam in Model.UpcomingExams)
                {
                    <div class="exam-row">
                        <div>
                            <div class="exam-row-title">@exam.ExamTitle</div>
                            <div class="exam-row-sub">@exam.CourseTitle · @exam.StartTime.ToLocalTime().ToString("MMM dd, hh:mm tt")</div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Recent Results -->
    <div class="dash-block">
        <div class="dash-block-head">
            Recent Results
            <a href="@Url.Action("Index", "Courses", new { area = "Student" })" class="btn-action">My Courses</a>
        </div>
        <div class="dash-block-body">
            @if (!Model.RecentResults.Any())
            {
                <div class="empty-state" style="padding: 1rem;">No results yet</div>
            }
            else
            {
                @foreach (var result in Model.RecentResults)
                {
                    <div class="exam-row">
                        <div>
                            <div class="exam-row-title">@result.ExamTitle</div>
                            <div class="exam-row-sub">@result.CourseTitle</div>
                        </div>
                        <div style="display:flex;align-items:center;gap:8px;">
                            @if (result.IsTerminated)
                            {
                                <span class="score-pill score-fail">Terminated</span>
                            }
                            else if (!result.ResultsPublished || result.HasPendingGrading)
                            {
                                <span class="score-pill" style="background:#E2E8F0;color:#475569;">Pending Grading</span>
                            }
                            else
                            {
                                var passed = result.MaxScore > 0 && ((double)result.TotalScore / result.MaxScore * 100) >= 60;
                                <span class="score-pill @(passed ? "score-pass" : "score-fail")">@result.TotalScore/@result.MaxScore</span>
                            }
                            <a href="@Url.Action("Result", "Exam", new { area = "Student", submissionId = result.SubmissionId })" style="font-size:12px;color:var(--c-primary);text-decoration:none;">View</a>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>
