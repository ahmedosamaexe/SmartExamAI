@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Account Settings";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    var fullName = ViewBag.FullName as string ?? "";
    var email = ViewBag.Email as string ?? "";
}

<style>
    .form-title { font-size: 22px; font-weight: 600; color: var(--c-text); margin-bottom: 6px; letter-spacing: -0.3px; }
    .form-subtitle { font-size: 14px; color: var(--c-muted); margin-bottom: 2rem; }
    .info-label { font-size: 10px; text-transform: uppercase; letter-spacing: .5px; color: var(--c-muted); font-weight: 600; margin-bottom: 4px; }
    .info-value { background: #F8F8F6; padding: 10px 13px; border-radius: 7px; font-size: 13px; color: var(--c-text); }
    .info-note { font-size: 11px; color: var(--c-muted); margin-top: 4px; }
    .info-group { margin-bottom: 16px; }
    .section-divider { border: none; border-top: 1px solid var(--c-border); margin: 24px 0; }
    .form-label { font-size: 13px; font-weight: 500; color: var(--c-text); margin-bottom: 6px; display: block; }
    .form-control {
        width: 100%; padding: 10px 14px; font-size: 14px; color: var(--c-text);
        background: #fff; border: 1px solid var(--c-border); border-radius: 8px;
        outline: none; transition: border-color .15s;
    }
    .form-control:focus { border-color: var(--c-primary); box-shadow: 0 0 0 3px rgba(106,143,106,0.12); }
    .input-wrap { margin-bottom: 1.25rem; }
    .strength-bar { height: 4px; border-radius: 2px; background: var(--c-border); margin-top: 8px; overflow: hidden; }
    .strength-fill { height: 100%; border-radius: 2px; transition: width .3s, background .3s; width: 0%; background: var(--c-border); }
    .strength-label { font-size: 11px; color: var(--c-muted); margin-top: 4px; }
    .btn-submit {
        width: 100%; padding: 11px; background: var(--c-primary); color: #fff;
        border: none; border-radius: 8px; font-size: 15px; font-weight: 500;
        cursor: pointer; transition: background .15s; margin-top: .5rem;
    }
    .btn-submit:hover { background: var(--c-primary-hover); }
    .btn-skip {
        width: 100%; padding: 11px; background: transparent; color: var(--c-muted);
        border: 1px solid var(--c-border); border-radius: 8px; font-size: 15px; font-weight: 500;
        cursor: pointer; transition: all .15s; margin-top: .75rem;
    }
    .btn-skip:hover { background: #F5F4F0; color: var(--c-text); }
    .field-error { font-size: 12px; color: var(--c-danger); margin-top: 4px; display: block; }
</style>

<div class="form-title">Account Settings</div>
<div class="form-subtitle">Your profile information and password settings</div>

<!-- Profile info -->
<div class="info-group">
    <div class="info-label">Full Name</div>
    <div class="info-value">@fullName</div>
</div>
<div class="info-group">
    <div class="info-label">Email</div>
    <div class="info-value">@email</div>
</div>
<div class="info-note">To change your name, contact your administrator.</div>

<hr class="section-divider" />

<div style="font-size: 15px; font-weight: 600; color: var(--c-text); margin-bottom: 16px;">Change Password</div>

<form asp-action="ChangePassword" method="post">
    <div class="input-wrap">
        <label class="form-label field-required" asp-for="CurrentPassword">Current password</label>
        <input class="form-control" asp-for="CurrentPassword" type="password" autocomplete="current-password" />
        <span class="field-error" asp-validation-for="CurrentPassword"></span>
    </div>

    <div class="input-wrap">
        <label class="form-label field-required" asp-for="NewPassword">New password</label>
        <input class="form-control" asp-for="NewPassword" type="password" id="newPassword" autocomplete="new-password" />
        <div id="strength-bar" style="height:4px;border-radius:2px;margin-top:6px;background:var(--c-border);transition:all 0.3s;">
          <div id="strength-fill" style="height:100%;border-radius:2px;width:0%;transition:all 0.3s;"></div>
        </div>
        <small id="strength-label" style="color:var(--c-muted);font-size:0.78rem;"></small>
        <span class="field-error" asp-validation-for="NewPassword"></span>
    </div>

    <div class="input-wrap">
        <label class="form-label field-required" asp-for="ConfirmNewPassword">Confirm new password</label>
        <input class="form-control" asp-for="ConfirmNewPassword" type="password" autocomplete="new-password" />
        <span class="field-error" asp-validation-for="ConfirmNewPassword"></span>
    </div>

    <button type="submit" class="btn-submit">Update password</button>
</form>



@section Scripts {
    <script>
        document.getElementById('newPassword').addEventListener('input', function() {
            var val = this.value;
            var fill = document.getElementById('strength-fill');
            var label = document.getElementById('strength-label');
            
            if (!val) { fill.style.width = '0%'; label.innerText = ''; return; }
            
            const hasNum = /\d/.test(val);
            const hasUpper = /[A-Z]/.test(val);
            const hasSym = /[^a-zA-Z0-9]/.test(val);
            const len = val.length;

            if (len >= 10 && hasUpper && hasNum && hasSym) {
                fill.style.width = '100%'; fill.style.backgroundColor = 'var(--c-success)'; label.innerText = 'Strong';
            } else if (len >= 8 && hasUpper && hasNum) {
                fill.style.width = '75%'; fill.style.backgroundColor = 'var(--c-warning)'; label.innerText = 'Good';
            } else if (len >= 6 && (hasNum || hasSym)) {
                fill.style.width = '50%'; fill.style.backgroundColor = 'var(--c-warning)'; label.innerText = 'Fair';
            } else {
                fill.style.width = '25%'; fill.style.backgroundColor = 'var(--c-danger)'; label.innerText = 'Weak';
            }
        });
    </script>
}
