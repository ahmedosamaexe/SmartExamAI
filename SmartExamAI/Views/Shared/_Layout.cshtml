<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartExam AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* Top Navbar */
        .top-navbar {
            background: var(--c-card);
            border-bottom: 1px solid var(--c-border);
            padding: 0 1.25rem;
            height: 56px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 1030;
        }
        .top-left { display: flex; align-items: center; gap: 12px; }
        .drawer-toggle {
            background: none; border: none; cursor: pointer;
            color: var(--c-text); font-size: 20px; padding: 4px;
            display: flex; align-items: center;
        }
        .brand-link { text-decoration: none; }
        .brand-name { font-size: 1.1rem; font-weight: 700; color: var(--c-primary); }

        /* Sidebar Drawer */
        .sidebar-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,0.3); z-index: 1040;
        }
        .sidebar-overlay.open { display: block; }
        .sidebar {
            position: fixed; top: 0; left: -280px;
            width: 280px; height: 100vh;
            background: var(--c-sidebar-bg); z-index: 1050;
            transition: left 0.25s ease;
            display: flex; flex-direction: column;
            overflow-y: auto;
        }
        .sidebar.open { left: 0; }

        .sidebar-header {
            padding: 20px 20px 16px;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }
        .sidebar-brand { font-size: 1.1rem; font-weight: 700; color: #fff; }
        .sidebar-brand-sub { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1px; color: var(--c-sidebar-text); margin-top: 2px; }

        .sidebar-nav { padding: 12px 0; flex: 1; }
        .sidebar-link {
            display: flex; align-items: center; gap: 12px;
            padding: 10px 20px; color: var(--c-sidebar-text);
            text-decoration: none; font-size: 14px; font-weight: 500;
            transition: all 0.15s; border-left: 3px solid transparent;
        }
        .sidebar-link:hover { background: rgba(255,255,255,0.06); color: #fff; }
        .sidebar-link.active {
            background: rgba(17,119,209,0.15); color: #fff;
            border-left-color: var(--c-primary);
        }
        .sidebar-link i { font-size: 18px; width: 22px; text-align: center; }

        .sidebar-section { padding: 16px 20px 6px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,0.3); }

        .sidebar-footer {
            padding: 16px 20px;
            border-top: 1px solid rgba(255,255,255,0.08);
        }
        .sidebar-user { display: flex; align-items: center; gap: 10px; }
        .sidebar-avatar {
            width: 34px; height: 34px; border-radius: 50%;
            background: var(--c-primary); color: #fff;
            display: flex; align-items: center; justify-content: center;
            font-weight: 600; font-size: 13px; flex-shrink: 0;
        }
        .sidebar-uname { font-size: 13px; color: #fff; font-weight: 500; }
        .sidebar-urole { font-size: 11px; color: var(--c-sidebar-text); }

        /* Avatar in top bar */
        .user-menu { position: relative; }
        .avatar-btn {
            background: var(--c-primary); color: #fff; border: none; border-radius: 50%;
            width: 36px; height: 36px; font-weight: 600; font-size: 0.85rem;
            cursor: pointer; display: flex; align-items: center; justify-content: center;
        }
        .avatar-menu {
            display: none; position: absolute; right: 0; top: 44px;
            background: var(--c-card); border: 1px solid var(--c-border); border-radius: 8px;
            min-width: 200px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); z-index: 1000; padding: 0.4rem 0;
        }
        .avatar-menu.show { display: block; }
        .avatar-menu-header { padding: 0.6rem 1rem; border-bottom: 1px solid var(--c-border); margin-bottom: 0.3rem; }
        .avatar-menu-name { font-size: 0.9rem; font-weight: 600; color: var(--c-text); }
        .avatar-menu-role { font-size: 0.7rem; color: var(--c-muted); margin-top: 1px; }
        .avatar-menu-item {
            display: flex; align-items: center; gap: 8px;
            padding: 0.5rem 1rem; font-size: 0.85rem; color: var(--c-text);
            text-decoration: none; transition: background 0.15s;
        }
        .avatar-menu-item:hover { background: #F8F9FA; color: var(--c-primary); }
        .avatar-menu-item.danger:hover { color: var(--c-danger); }

        /* Main content area */
        .main-wrap { min-height: calc(100vh - 56px); background: var(--c-page-bg); }
        .main-content { padding: 1.5rem; max-width: 1400px; margin: 0 auto; width: 100%; }
    </style>
</head>
<body style="background-color: var(--c-page-bg);">

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? "";

    bool IsActive(string controller, string alsoMatch = "")
    {
        var match = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
        if (!match && !string.IsNullOrEmpty(alsoMatch))
        {
            match = string.Equals(currentController, alsoMatch, StringComparison.OrdinalIgnoreCase);
        }
        return match;
    }

    var fullName = User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value ?? User.Identity?.Name ?? "User";
    var role = User.IsInRole("Teacher") ? "Teacher" : "Student";
    var initials = "";
    if (!string.IsNullOrEmpty(fullName))
    {
        var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        initials = parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
            : parts[0][..Math.Min(2, parts[0].Length)].ToUpper();
    }
}

<!-- Sidebar Overlay -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<!-- Sidebar Drawer -->
<aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <div class="sidebar-brand">SmartExam AI</div>
        <div class="sidebar-brand-sub">Examination Platform</div>
    </div>

    <nav class="sidebar-nav">
        @if (User.IsInRole("Teacher"))
        {
            <div class="sidebar-section">Main</div>
            <a href="@Url.Action("Index", "Dashboard", new { area = "Teacher" })" class="sidebar-link @(IsActive("Dashboard") ? "active" : "")" onclick="closeSidebar()">
                <i class="bi bi-grid-1x2"></i> Dashboard
            </a>
            <a href="@Url.Action("Index", "Courses", new { area = "Teacher" })" class="sidebar-link @(IsActive("Courses", "Exams") || IsActive("Results") ? "active" : "")" onclick="closeSidebar()">
                <i class="bi bi-journal-text"></i> My Courses
            </a>
        }
        else if (User.IsInRole("Student"))
        {
            <div class="sidebar-section">Main</div>
            <a href="@Url.Action("Index", "Dashboard", new { area = "Student" })" class="sidebar-link @(IsActive("Dashboard") ? "active" : "")" onclick="closeSidebar()">
                <i class="bi bi-grid-1x2"></i> Dashboard
            </a>
            <a href="@Url.Action("Index", "Courses", new { area = "Student" })" class="sidebar-link @(IsActive("Courses") || IsActive("Exam") ? "active" : "")" onclick="closeSidebar()">
                <i class="bi bi-journal-text"></i> My Courses
            </a>
        }

        <div class="sidebar-section">Account</div>
        <a href="/Account/Profile" class="sidebar-link" onclick="closeSidebar()">
            <i class="bi bi-person"></i> Profile
        </a>
    </nav>

    <div class="sidebar-footer">
        <div class="sidebar-user">
            <div class="sidebar-avatar">@initials</div>
            <div>
                <div class="sidebar-uname">@fullName</div>
                <div class="sidebar-urole">@role</div>
            </div>
        </div>
    </div>
</aside>

<!-- Top Navbar -->
<nav class="top-navbar">
    <div class="top-left">
        <button class="drawer-toggle" onclick="toggleSidebar()" aria-label="Menu">
            <i class="bi bi-list"></i>
        </button>
        <a href="/" class="brand-link">
            <span class="brand-name">SmartExam AI</span>
        </a>
    </div>

    <div style="display: flex; align-items: center; gap: 0.75rem;">
        <div class="user-menu">
            <button id="avatar-btn" class="avatar-btn">@initials</button>
            <div id="avatar-menu" class="avatar-menu">
                <div class="avatar-menu-header">
                    <div class="avatar-menu-name">@fullName</div>
                    <div class="avatar-menu-role">@role</div>
                </div>
                <a href="/Account/Profile" class="avatar-menu-item">
                    <i class="bi bi-person-circle"></i> Profile
                </a>
                <form method="post" action="/Account/Logout" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="avatar-menu-item danger" style="width:100%; border:none; background:none; text-align:left; cursor:pointer;">
                        <i class="bi bi-box-arrow-right"></i> Sign out
                    </button>
                </form>
            </div>
        </div>
    </div>
</nav>

<!-- Main area -->
<div class="main-wrap">
    <div class="main-content">
        @if (TempData["Error"] != null)
        {
            <script>document.addEventListener('DOMContentLoaded',()=>showToast('@TempData["Error"]','danger'));</script>
        }
        @if (TempData["Success"] != null)
        {
            <script>document.addEventListener('DOMContentLoaded',()=>showToast('@TempData["Success"]','success'));</script>
        }

        @await RenderSectionAsync("Breadcrumb", required: false)
        @RenderBody()
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
<div id="toast-container" style="position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;display:flex;flex-direction:column;gap:8px;"></div>
<script>
function showToast(message, type = 'success') {
  const colors = { success: 'var(--c-success)', danger: 'var(--c-danger)', warning: 'var(--c-warning)' };
  const t = document.createElement('div');
  t.style.cssText = `background:#fff;border-left:4px solid ${colors[type]};padding:0.75rem 1.25rem;border-radius:8px;box-shadow:0 4px 16px rgba(0,0,0,0.1);font-size:0.875rem;min-width:260px;color:var(--c-text);`;
  t.innerText = message;
  document.getElementById('toast-container').appendChild(t);
  setTimeout(() => t.remove(), 4000);
}

// Sidebar
function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('sidebarOverlay').classList.toggle('open');
}
function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('open');
}

// Avatar menu
document.getElementById('avatar-btn').addEventListener('click', function(e) {
  e.stopPropagation();
  document.getElementById('avatar-menu').classList.toggle('show');
});
document.addEventListener('click', () => {
  const menu = document.getElementById('avatar-menu');
  if (menu) menu.classList.remove('show');
});
</script>
</body>
</html>
