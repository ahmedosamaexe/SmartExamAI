<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SmartExam AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        html, body { height: 100%; margin: 0; padding: 0; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; }

        .auth-split {
            display: flex;
            min-height: 100vh;
        }

        /* ── Left branding panel ── */
        .auth-left {
            flex: 1;
            background: var(--c-sidebar-bg);
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 48px;
        }
        .auth-left-label {
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 0.5px;
            color: var(--c-primary);
            margin-bottom: 16px;
        }
        .auth-left h1 {
            font-size: 28px;
            font-weight: 700;
            color: #fff;
            letter-spacing: -0.5px;
            line-height: 1.3;
            margin-bottom: 12px;
        }
        .auth-left-desc {
            font-size: 14px;
            color: var(--c-muted);
            max-width: 300px;
            line-height: 1.6;
            margin-bottom: 32px;
        }

        /* ── Feature cards ── */
        .auth-features {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .auth-feature-card {
            background: #252527;
            border-radius: 8px;
            padding: 12px 16px;
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }
        .auth-feature-icon {
            width: 32px;
            height: 32px;
            min-width: 32px;
            border-radius: 7px;
            background: var(--c-primary);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .auth-feature-icon svg {
            width: 16px;
            height: 16px;
        }
        .auth-feature-title {
            font-size: 13px;
            color: #ccc;
            font-weight: 500;
            margin-bottom: 2px;
        }
        .auth-feature-sub {
            font-size: 12px;
            color: var(--c-muted);
        }

        /* ── Right form panel ── */
        .auth-right {
            width: 400px;
            flex-shrink: 0;
            background: var(--c-card);
            padding: 48px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        @@media (max-width: 767.98px) {
            .auth-right {
                width: 100%;
                padding: 32px 24px;
            }
        }
    </style>
</head>
<body>
<div class="auth-split">
    <!-- Left panel — hidden on mobile -->
    <div class="auth-left d-none d-md-flex">
        <div class="auth-left-label">SMARTEXAM AI</div>
        <h1>Smarter Exams, Fairer Results.</h1>
        <p class="auth-left-desc">An AI-powered examination platform with real-time behavior monitoring and automated proctoring.</p>

        <div class="auth-features">
            <!-- Real-Time Proctoring -->
            <div class="auth-feature-card">
                <div class="auth-feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                </div>
                <div>
                    <div class="auth-feature-title">Real-Time Proctoring</div>
                    <div class="auth-feature-sub">Fullscreen, tab-switch, and copy detection</div>
                </div>
            </div>

            <!-- Instant Analytics -->
            <div class="auth-feature-card">
                <div class="auth-feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="20" x2="18" y2="10"/>
                        <line x1="12" y1="20" x2="12" y2="4"/>
                        <line x1="6" y1="20" x2="6" y2="14"/>
                    </svg>
                </div>
                <div>
                    <div class="auth-feature-title">Instant Analytics</div>
                    <div class="auth-feature-sub">Export results to Excel, grade short answers</div>
                </div>
            </div>

            <!-- Multi-Type Questions -->
            <div class="auth-feature-card">
                <div class="auth-feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="7"/>
                        <rect x="14" y="3" width="7" height="7"/>
                        <rect x="3" y="14" width="7" height="7"/>
                        <rect x="14" y="14" width="7" height="7"/>
                    </svg>
                </div>
                <div>
                    <div class="auth-feature-title">Multi-Type Questions</div>
                    <div class="auth-feature-sub">MCQ, True/False, and Short Answer</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right panel — form area -->
    <div class="auth-right">
        @RenderBody()
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
